# Copy this file to `.env` and fill in real values.
# Do NOT commit `.env` with real secrets.
#
# NOTE: none of the variables below are currently read by the Tauri app, the
# Rust backend, or the Python test tooling — none appear anywhere in src/ or
# src-tauri/src/. They are kept as a placeholder for optional file-based
# tooling some contributors may build. The desktop app reads AI keys from
# Settings (browser local storage), and the Google Calendar OAuth PKCE flow
# (see README.md) needs only a Client ID — no Client Secret and no redirect
# server, so GOOGLE_CLIENT_SECRET / GOOGLE_REDIRECT_URI below do not apply to
# the implemented flow.

# AI providers (optional; desktop app uses keys from the UI / localStorage)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest

# App defaults
APP_NAME=JobTracker
APP_ENV=development

# Local storage roots (relative to project root)
STORAGE_ROOT=./storage
JOB_POSTINGS_DIR=./storage/job-postings
APPLICATIONS_DIR=./storage/applications

# Google Calendar: the desktop app only needs a Client ID, entered in
# Settings — see README.md "Google Calendar" section. Not used by file-based
# tooling today; kept here for reference only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
