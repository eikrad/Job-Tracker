# Copy this file to `.env` and fill in real values.
# Do NOT commit `.env` with real secrets.

# AI providers (optional; desktop app uses keys from the UI / localStorage)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest

# App defaults
APP_NAME=JobTracker
APP_ENV=development

# Local storage roots (relative to project root)
STORAGE_ROOT=./storage
JOB_POSTINGS_DIR=./storage/job-postings
APPLICATIONS_DIR=./storage/applications

# Optional calendar integration (can stay empty for now)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
